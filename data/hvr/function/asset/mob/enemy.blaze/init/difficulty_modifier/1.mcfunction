#> hvr:asset/mob/enemy.blaze/init/difficulty_modifier/1
#
# Weakest modifier
#
# @within function hvr:asset/mob/enemy.blaze/init/

# Grant modifier
    attribute @s armor modifier add hvr:asset/mob/enemy.blaze.armor.difficulty_modifier.1 10 add_value
    attribute @s attack_knockback modifier add hvr:asset/mob/enemy.blaze.attack_knockback.difficulty_modifier.1 1 add_value
    attribute @s knockback_resistance modifier add hvr:asset/mob/enemy.blaze.knockback_resistance.difficulty_modifier.1 0.4 add_value